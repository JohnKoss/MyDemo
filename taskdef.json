{
    "family": "mydemo-task",
    "executionRoleArn": "arn:aws:iam::737782568138:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "containerDefinitions": [
      {
        "name": "mydemo-container",
        "image": "<IMAGE1_NAME>",
        "essential": true,
        "portMappings": [
          {
            "containerPort": 80,
            "hostPort": 80,
            "protocol": "tcp"
          }
        ]
      }
    ],
    "requiresCompatibilities": [
      "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "taskRoleArn": "arn:aws:iam::737782568138:role/appTaskRole"
  }
  
